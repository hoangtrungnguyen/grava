#!/bin/bash

# Pre-commit hook for Grava
# Exports change from Dolt database to issues.jsonl before committing

ISSUE_FILE="issues.jsonl"
echo "🔍 pre-commit: Exporting current issues to $ISSUE_FILE..."

# Resolve 'grava' command
GRAVA_CMD=""
if command -v grava >/dev/null 2>&1; then
    GRAVA_CMD="grava"
else
    REPO_ROOT=$(git rev-parse --show-toplevel)
    if [ -x "$REPO_ROOT/grava" ]; then
        GRAVA_CMD="$REPO_ROOT/grava"
    elif [ -f "$REPO_ROOT/cmd/grava/main.go" ]; then
        GRAVA_CMD="go run $REPO_ROOT/cmd/grava/main.go"
    fi
fi

if [ -n "$GRAVA_CMD" ]; then
    # Export only non-ephemeral, including tombstones (fully sync text storage)
    $GRAVA_CMD export --file "$ISSUE_FILE"
    if [ $? -eq 0 ]; then
        # Check if file changed
        git add "$ISSUE_FILE"
        echo "✅ $ISSUE_FILE updated and staged for commit."
    else
        echo "❌ FAILED to export issues. Commit aborted."
        exit 1
    fi
else
    echo "⚠️  Grava not found. Skipping auto-export."
fi

exit 0
