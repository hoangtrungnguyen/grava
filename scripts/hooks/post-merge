#!/bin/bash

# Post-merge hook for Grava
# Syncs changes from issues.jsonl into the Dolt database after a merge or pull

ISSUE_FILE="issues.jsonl"
if [ ! -f "$ISSUE_FILE" ]; then
    # No issues file, nothing to sync
    exit 0
fi

echo "🔄 post-merge: Syncing issues from $ISSUE_FILE to Dolt database..."

# Resolve 'grava' command
GRAVA_CMD=""
if command -v grava >/dev/null 2>&1; then
    GRAVA_CMD="grava"
else
    # Fallback to local source root
    REPO_ROOT=$(git rev-parse --show-toplevel)
    if [ -x "$REPO_ROOT/grava" ]; then
        GRAVA_CMD="$REPO_ROOT/grava"
    elif [ -f "$REPO_ROOT/cmd/grava/main.go" ]; then
        GRAVA_CMD="go run $REPO_ROOT/cmd/grava/main.go"
    fi
fi

if [ -n "$GRAVA_CMD" ]; then
    $GRAVA_CMD import --file "$ISSUE_FILE" --overwrite
    if [ $? -eq 0 ]; then
        echo "✅ Issues synchronized successfully."
    else
        echo "❌ FAILED to synchronize issues. Run 'grava doctor' to debug."
    fi
else
    echo "⚠️  Grava not found. Skipping sync."
fi

exit 0
