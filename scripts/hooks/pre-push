#!/bin/bash

# Pre-push hook for Grava
# Stops any running Dolt SQL server before pushing to remote repository

echo "🔍 Pre-push hook: Stopping Dolt SQL server..."

# Try to use the installed 'grava' binary first
if command -v grava >/dev/null 2>&1; then
    grava stop
else
    # Fallback to 'go run' if we're in the repository root
    REPO_ROOT=$(git rev-parse --show-toplevel)
    if [ -f "$REPO_ROOT/cmd/grava/main.go" ]; then
        go run "$REPO_ROOT/cmd/grava/main.go" stop
    else
        echo "⚠️  Grava not found in PATH and no local main.go found. Skipping stop."
    fi
fi

# We don't want to prevent the push even if stopping failed
exit 0
